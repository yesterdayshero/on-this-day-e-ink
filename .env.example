# Required
GEMINI_API_KEY=your_key_here          # Image generation + scoring
TRMNL_WEBHOOK_URL=https://trmnl.com/api/plugin_settings/YOUR_UUID/image

# Optional
GEMINI_SCORING_API_KEY=               # If set, used for scoring instead (free-tier key saves cost)
DISCORD_WEBHOOK_URL=                  # Daily digest and failure alerts
IMAGE_STYLE=sketch                    # Image style: woodcut or sketch (default: sketch)
LOG_LEVEL=INFO
TIMEZONE=UTC                      # Change to your local timezone (Format: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
